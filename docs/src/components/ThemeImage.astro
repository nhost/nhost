---
import { Image } from 'astro:assets';

interface Props {
  light: string;
  dark: string;
  alt: string;
  width: number;
  height: number;
  class?: string;
}

const { light, dark, alt, width, height, class: className } = Astro.props;
---

<span class={className} data-theme-image>
  <Image src={light} alt={alt} width={width} height={height} class="theme-image theme-image-light" loading="lazy" decoding="async" />
  <Image src={dark} alt={alt} width={width} height={height} class="theme-image theme-image-dark" loading="lazy" decoding="async" />
</span>

<style>
  [data-theme-image] {
    display: block;
  }

  .theme-image {
    max-width: 100%;
    height: auto;
  }

  .theme-image-light {
    display: none;
  }

  .theme-image-dark {
    display: block;
  }

  :global(html[data-theme='light']) .theme-image-light {
    display: block;
  }

  :global(html[data-theme='light']) .theme-image-dark {
    display: none;
  }
</style>
