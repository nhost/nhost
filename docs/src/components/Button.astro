---
interface Props {
  icon?: string;
  label?: string;
  title?: string;
}

const { icon, label, title } = Astro.props;

// Heroicons-style SVG icons (outline, 24x24), matching Card.astro.
const iconMap: Record<string, string> = {
  eye: '<path stroke-linecap="round" stroke-linejoin="round" d="M2.036 12.322a1.012 1.012 0 0 1 0-.639C3.423 7.51 7.36 4.5 12 4.5c4.638 0 8.573 3.007 9.963 7.178.07.207.07.431 0 .639C20.577 16.49 16.64 19.5 12 19.5c-4.638 0-8.573-3.007-9.963-7.178Z" /><path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z" />',
  copy: '<path stroke-linecap="round" stroke-linejoin="round" d="M15.75 17.25v3.375c0 .621-.504 1.125-1.125 1.125h-9.75a1.125 1.125 0 0 1-1.125-1.125V7.875c0-.621.504-1.125 1.125-1.125H6.75a9.06 9.06 0 0 1 1.5.124m7.5 10.376h3.375c.621 0 1.125-.504 1.125-1.125V11.25c0-4.46-3.243-8.161-7.5-8.876a9.06 9.06 0 0 0-1.5-.124H9.375c-.621 0-1.125.504-1.125 1.125v3.5m7.5 10.375H9.375a1.125 1.125 0 0 1-1.125-1.125v-9.25m12 6.625v-1.875a3.375 3.375 0 0 0-3.375-3.375h-1.5a1.125 1.125 0 0 1-1.125-1.125v-1.5a3.375 3.375 0 0 0-3.375-3.375H9.75" />',
  refresh:
    '<path stroke-linecap="round" stroke-linejoin="round" d="M16.023 9.348h4.992v-.001M2.985 19.644v-4.992m0 0h4.992m-4.993 0 3.181 3.183a8.25 8.25 0 0 0 13.803-3.7M4.031 9.865a8.25 8.25 0 0 1 13.803-3.7l3.181 3.182m0-4.991v4.99" />',
};

const iconSvg = icon ? (iconMap[icon] ?? null) : null;

// Renders as an inline chip that mirrors the dashboard's buttons. Styles are inline so
// they beat Starlight's `.sl-markdown-content svg { display:block; height:auto }` rule.
// Icon-only buttons use balanced padding so they read as a square, like the dashboard.
const padding = label ? '0.25em 0.55em' : '0.25em 0.3em';
const wrapperStyle = [
  'display:inline-flex',
  'align-items:center',
  'gap:0.3em',
  `padding:${padding}`,
  'border:1px solid var(--sl-color-gray-4)',
  'border-radius:0.4em',
  'vertical-align:middle',
  'line-height:1',
  'white-space:nowrap',
  'font-size:0.9em',
].join(';');

const iconStyle =
  'display:inline-block;width:1em;height:1em;flex-shrink:0;vertical-align:middle;';
---

<span style={wrapperStyle}>
  {label && <span>{label}</span>}
  {iconSvg && (
    <svg
      xmlns="http://www.w3.org/2000/svg"
      fill="none"
      viewBox="0 0 24 24"
      stroke-width="1.5"
      stroke="currentColor"
      role={label ? undefined : 'img'}
      aria-label={label ? undefined : title}
      aria-hidden={label ? 'true' : undefined}
      style={iconStyle}
      set:html={iconSvg}
    />
  )}
</span>
