---
interface Props {
  text: string;
}

const { text } = Astro.props;
---

<span class="copy-text">
  <code>{text}</code>
  <button class="copy-text-btn" type="button" data-copy={text} aria-label="Copy to clipboard">
    <svg
      width="14"
      height="14"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="2"
      stroke-linecap="round"
      stroke-linejoin="round"
    >
      <rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect>
      <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path>
    </svg>
  </button>
  <span class="copy-text-tooltip" role="status" aria-live="polite">
    Copied
    <svg
      width="12"
      height="12"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="3"
      stroke-linecap="round"
      stroke-linejoin="round"
    >
      <polyline points="20 6 9 17 4 12"></polyline>
    </svg>
  </span>
</span>

<style>
  /* Single inline pill so the URL and copy button read as one unit. */
  .copy-text {
    position: relative;
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.125rem 0.375rem 0.125rem 0.5rem;
    border-radius: 0.375rem;
    background: var(--sl-color-bg-inline-code);
    white-space: nowrap;
    vertical-align: baseline;
  }

  /* Drop the default inline-code chip styling so the pill isn't doubled up. */
  .copy-text code {
    padding: 0;
    border: none;
    background: transparent;
  }

  .copy-text-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.125rem;
    background: transparent;
    border: none;
    border-radius: 0.25rem;
    color: inherit;
    opacity: 0.6;
    cursor: pointer;
    line-height: 0;
    transition: opacity 0.15s;
  }

  .copy-text-btn:hover {
    opacity: 1;
  }

  .copy-text-tooltip {
    position: absolute;
    bottom: calc(100% + 4px);
    right: 0;
    display: inline-flex;
    align-items: center;
    gap: 0.25rem;
    padding: 0.25rem 0.5rem;
    border: 1px solid var(--sl-color-hairline-light);
    border-radius: 0.375rem;
    background: var(--sl-color-gray-5);
    color: var(--sl-color-gray-1);
    font-family: var(--sl-font);
    font-size: 0.75rem;
    font-weight: 500;
    line-height: 1;
    white-space: nowrap;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.15);
    opacity: 0;
    visibility: hidden;
    transform: translateY(4px);
    /* Animate the disappear (fade + slide down). */
    transition: opacity 0.2s, transform 0.2s, visibility 0.2s;
    pointer-events: none;
    z-index: 10;
  }

  .copy-text-btn.copied ~ .copy-text-tooltip {
    opacity: 1;
    visibility: visible;
    transform: translateY(0);
    /* Appear instantly; the base rule animates it back out. */
    transition: none;
  }
</style>

<script>
  let controller: AbortController;
  const timers = new WeakMap<HTMLElement, ReturnType<typeof setTimeout>>();

  function initCopyText() {
    controller?.abort();
    controller = new AbortController();
    const { signal } = controller;

    document.querySelectorAll<HTMLButtonElement>('.copy-text-btn').forEach((btn) => {
      btn.addEventListener(
        'click',
        () => {
          const text = btn.dataset.copy || '';
          navigator.clipboard
            .writeText(text)
            .then(() => {
              clearTimeout(timers.get(btn));
              btn.classList.add('copied');
              timers.set(
                btn,
                setTimeout(() => btn.classList.remove('copied'), 2000),
              );
            })
            .catch(() => {});
        },
        { signal },
      );
    });
  }

  initCopyText();
  document.addEventListener('astro:after-swap', initCopyText);
</script>
