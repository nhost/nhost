{
  "manifest_version": 3,
  "name": "Nhost Screenshot Tool",
  "version": "0.1.0",
  "description": "Internal dev tool: compose docs/dashboard screenshots (dim, spotlight, outline) on any page.",
  "minimum_chrome_version": "120",
  "permissions": ["activeTab", "scripting", "downloads", "clipboardWrite"],
  "host_permissions": ["http://*/*", "https://*/*"],
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["http://*/*", "https://*/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "commands": {
    "toggle-tool": {
      "suggested_key": {
        "default": "Ctrl+Shift+S",
        "mac": "Command+Shift+S"
      },
      "description": "Toggle screenshot tool on the current tab"
    }
  },
  "action": {
    "default_title": "Toggle screenshot tool",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  }
}
