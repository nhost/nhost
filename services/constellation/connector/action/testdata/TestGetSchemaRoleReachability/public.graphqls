schema {
  query: Query
}
"""
ISO-8601 timestamp.
"""
scalar DateTime
"""
Action lifecycle state.
"""
enum ActionStatus {
  """
  The action completed.
  """
  OK
  """
  Legacy state.
  """
  OLD @deprecated(reason: "Use OK instead.")
}
type Query {
  """
  Searches the public catalog.
  """
  searchCatalog(
    """
    Search constraints.
    """
    filter: SearchFilter!
  ): [SearchResult!]!
}
"""
One search hit.
"""
type SearchResult {
  """
  Stable identifier.
  """
  id: ID!
  """
  Display title.
  """
  title: String!
  """
  Current status.
  """
  status: ActionStatus!
  """
  Creation time.
  """
  createdAt: DateTime!
}
"""
Search filter input.
"""
input SearchFilter {
  """
  Free-text search term.
  """
  term: String!
  """
  Lower creation bound.
  """
  since: DateTime
  """
  Status filter.
  """
  status: ActionStatus
}
